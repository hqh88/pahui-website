---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getSeo } from '../data/reader';

interface Props {
  title: string;
  description?: string;
  ogImage?: string | null;
  keywords?: string;
}

const seo = await getSeo();
const { title, description, ogImage, keywords } = Astro.props;

const metaDescription = description || seo.defaultDescription || '';
const metaOgImage = ogImage || seo.defaultOgImage || '';
const metaKeywords = keywords || seo.keywords || '';
const fullTitle = title.includes(seo.siteName) ? title : `${title} | ${seo.siteName}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site || 'https://furniturepahui.com');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    {metaKeywords && <meta name="keywords" content={metaKeywords} />}
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    {metaOgImage && <meta property="og:image" content={metaOgImage} />}
    <meta property="og:site_name" content={seo.siteName} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    {metaOgImage && <meta name="twitter:image" content={metaOgImage} />}

    <!-- Google Verification -->
    {seo.googleVerification && <meta name="google-site-verification" content={seo.googleVerification} />}

    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet" />
    {seo.analyticsEnabled && seo.analyticsWebsiteId && (
      <script defer src={seo.analyticsScriptUrl || 'https://cloud.umami.is/script.js'} data-website-id={seo.analyticsWebsiteId}></script>
    )}
  </head>
  <body class="bg-bg text-text font-sans min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
