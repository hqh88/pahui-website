---
import Layout from '../layouts/Layout.astro';
import { getAbout } from '../data/reader';

export const prerender = true;

const about = await getAbout();
const { storyImage, storyTitle, storyParagraphs, values } = about!;
---

<Layout title="About Us - PA HUI Furniture">
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="font-heading text-3xl font-semibold text-center mb-10">About PA HUI Furniture</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-16">
      <div>
        <img
          src={storyImage}
          alt="About PA HUI"
          class="rounded-lg w-full"
        />
      </div>
      <div>
        <h2 class="font-heading text-xl font-semibold mb-4">{storyTitle}</h2>
        {storyParagraphs.map((p, i) => (
          <p class:list={["text-text-light leading-relaxed", { "mb-4": i < storyParagraphs.length - 1 }]}>{p}</p>
        ))}
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
      {values.map((v) => (
        <div class="p-6 bg-primary-light rounded-lg">
          <div class="text-3xl font-heading font-bold text-primary mb-2">{v.title}</div>
          <p class="text-text-light text-sm">{v.description}</p>
        </div>
      ))}
    </div>
  </section>
</Layout>
