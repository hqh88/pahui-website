---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us - PA HUI Furniture">
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="font-heading text-3xl font-semibold text-center mb-10">About PA HUI Furniture</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-16">
      <div>
        <img
          src="/images/hero/hero-3.jpg"
          alt="About PA HUI"
          class="rounded-lg w-full"
        />
      </div>
      <div>
        <h2 class="font-heading text-xl font-semibold mb-4">Our Story</h2>
        <p class="text-text-light leading-relaxed mb-4">
          PA HUI Furniture is dedicated to bringing premium quality furniture to homes.
          Our curated collection features pieces that blend timeless design with modern comfort.
        </p>
        <p class="text-text-light leading-relaxed">
          We work directly with skilled craftspeople to ensure every piece meets our high standards
          of quality, durability, and aesthetic appeal.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
      <div class="p-6 bg-primary-light rounded-lg">
        <div class="text-3xl font-heading font-bold text-primary mb-2">Quality</div>
        <p class="text-text-light text-sm">Premium materials and expert craftsmanship in every piece</p>
      </div>
      <div class="p-6 bg-primary-light rounded-lg">
        <div class="text-3xl font-heading font-bold text-primary mb-2">Design</div>
        <p class="text-text-light text-sm">Timeless aesthetics that complement any home</p>
      </div>
      <div class="p-6 bg-primary-light rounded-lg">
        <div class="text-3xl font-heading font-bold text-primary mb-2">Service</div>
        <p class="text-text-light text-sm">Personalized attention from selection to delivery</p>
      </div>
    </div>
  </section>
</Layout>
