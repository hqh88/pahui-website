---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getCollectionsWithProducts } from '../../data/reader';

export const prerender = true;

export async function getStaticPaths() {
  const collections = await getCollectionsWithProducts();
  return collections.map((col) => ({
    params: { slug: col.slug },
    props: { collection: col },
  }));
}

const { collection } = Astro.props;
const collections = await getCollectionsWithProducts();
---

<Layout
  title={`${collection.name} - PA HUI Furniture`}
  description={`Browse our ${collection.name.toLowerCase()} collection. ${collection.products.length} premium products available.`}
>
  <section class="max-w-7xl mx-auto px-4 py-12">
    <h1 class="font-heading text-3xl font-semibold mb-2">{collection.name}</h1>
    <p class="text-text-light text-sm mb-8">{collection.products.length} products</p>

    <!-- Category Filter -->
    <div class="flex flex-wrap gap-2 mb-8">
      <a
        href="/collections"
        class="px-4 py-2 bg-bg-alt text-text-light text-sm rounded-full hover:bg-primary hover:text-white transition-colors"
      >
        All
      </a>
      {collections.map((col) => (
        <a
          href={`/collections/${col.slug}`}
          class:list={[
            "px-4 py-2 text-sm rounded-full transition-colors",
            col.slug === collection.slug
              ? "bg-primary text-white"
              : "bg-bg-alt text-text-light hover:bg-primary hover:text-white"
          ]}
          data-umami-event="filter-category" data-umami-event-category={col.name}
        >
          {col.name}
        </a>
      ))}
    </div>

    <!-- Product Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      {collection.products.map((product: any) => (
        <ProductCard
          id={product.id}
          name={product.name}
          image={product.image}
          category={product.category}
          size={product.size}
          customizable={product.customizable}
        />
      ))}
    </div>
  </section>
</Layout>
