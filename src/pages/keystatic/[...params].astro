---
import KeystaticApp from '../../components/KeystaticApp';

export const prerender = false;
---
<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Keystatic Admin</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      .admin-toolbar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 16px;
        background: #1c1c2e;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        font-family: system-ui, -apple-system, sans-serif;
        font-size: 13px;
      }
      .admin-toolbar-spacer { flex: 1; }
      .admin-toolbar a,
      .admin-toolbar button {
        padding: 4px 12px;
        border-radius: 4px;
        border: 1px solid rgba(255,255,255,0.12);
        background: transparent;
        color: rgba(255,255,255,0.7);
        font-size: 12px;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        transition: all 0.15s;
      }
      .admin-toolbar a:hover,
      .admin-toolbar button:hover {
        color: #fff;
        border-color: rgba(255,255,255,0.3);
      }
      #keystatic-root { height: calc(100vh - 37px); }
    </style>
  </head>
  <body>
    <div class="admin-toolbar">
      <span style="color: rgba(255,255,255,0.4);">PA HUI Admin</span>
      <div class="admin-toolbar-spacer"></div>
      <a href="/admin/analytics">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
        Analytics
      </a>
      <button id="locale-toggle">中文</button>
    </div>
    <div id="keystatic-root">
      <KeystaticApp client:only="react" />
    </div>
    <script>
      const STORAGE_KEY = 'keystatic-locale';
      const btn = document.getElementById('locale-toggle');
      const current = localStorage.getItem(STORAGE_KEY) || 'en';
      if (btn) btn.textContent = current === 'en' ? '中文' : 'EN';
      btn?.addEventListener('click', () => {
        const next = (localStorage.getItem(STORAGE_KEY) || 'en') === 'en' ? 'zh' : 'en';
        localStorage.setItem(STORAGE_KEY, next);
        location.reload();
      });
    </script>
  </body>
</html>
