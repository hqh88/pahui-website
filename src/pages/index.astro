---
import Layout from '../layouts/Layout.astro';
import { getHomepage } from '../data/reader';

export const prerender = true;

const homepage = await getHomepage();
const { heroImage, heroTitle, heroSubtitle, heroButtonText, heroButtonLink, featuredCollections, slides, seoTitle, seoDescription, seoOgImage } = homepage as any;
---

<Layout
  title={seoTitle || 'PA HUI Furniture - Premium Furniture Collection'}
  description={seoDescription}
  ogImage={seoOgImage}
>
  <!-- Hero Section -->
  <section class="relative h-[70vh] min-h-[500px] overflow-hidden">
    <img
      src={heroImage}
      alt={heroTitle}
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/30"></div>
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="text-center bg-white/90 px-12 py-10 rounded-lg max-w-lg">
        <h1 class="font-heading text-3xl md:text-4xl font-bold text-text mb-3">{heroTitle}</h1>
        <p class="text-text-light mb-6">{heroSubtitle}</p>
        <a
          href={heroButtonLink}
          class="inline-block px-8 py-3 border-2 border-primary text-primary hover:bg-primary hover:text-white transition-colors text-sm font-medium tracking-wide"
          data-umami-event="hero-cta-click"
        >
          {heroButtonText}
        </a>
      </div>
    </div>
  </section>

  <!-- Shop by Collection -->
  <section class="max-w-7xl mx-auto px-4 py-16">
    <h2 class="font-heading text-2xl md:text-3xl font-semibold text-center mb-12">Shop by Collection</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {featuredCollections.map((item) => (
        <a href={`/collections/${item.slug}`} class="group text-center" data-umami-event="collection-click" data-umami-event-collection={item.name}>
          <div class="aspect-square bg-bg-alt rounded-lg overflow-hidden mb-3">
            <img
              src={item.image}
              alt={item.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <h3 class="text-sm font-medium group-hover:text-primary transition-colors">{item.name}</h3>
        </a>
      ))}
    </div>
  </section>


  <!-- Slideshow -->
  <section class="relative overflow-hidden" id="slideshow">
    <div class="relative h-[50vh] min-h-[400px]">
      {slides.map((slide, i) => (
        <div class={`slide absolute inset-0 transition-opacity duration-700 ${i === 0 ? 'opacity-100' : 'opacity-0'}`} data-slide={i}>
          <img src={slide.image} alt={slide.title} class="absolute inset-0 w-full h-full object-cover" />
          <div class="absolute inset-0 bg-black/30"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="bg-white/90 px-10 py-8 max-w-xl text-center rounded">
              <h2 class="font-heading text-2xl md:text-3xl font-semibold mb-3">{slide.title}</h2>
              <p class="text-text-light leading-relaxed">{slide.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Controls -->
    <div class="flex items-center justify-center gap-4 py-4 bg-white">
      <button id="slide-prev" class="text-text-light hover:text-text text-xl" aria-label="Previous slide">&lsaquo;</button>
      {slides.map((_, i) => (
        <button class={`slide-dot text-sm ${i === 0 ? 'font-medium text-text' : 'text-text-light'}`} data-goto={i}>{i + 1}</button>
      ))}
      <button id="slide-next" class="text-text-light hover:text-text text-xl" aria-label="Next slide">&rsaquo;</button>
    </div>
  </section>
</Layout>

<script>
  let current = 0;
  const slides = document.querySelectorAll('.slide');
  const dots = document.querySelectorAll('.slide-dot');
  const total = slides.length;

  function goTo(index: number) {
    slides[current].classList.remove('opacity-100');
    slides[current].classList.add('opacity-0');
    dots[current].classList.remove('text-text', 'font-medium');
    dots[current].classList.add('text-text-light');

    current = (index + total) % total;

    slides[current].classList.remove('opacity-0');
    slides[current].classList.add('opacity-100');
    dots[current].classList.remove('text-text-light');
    dots[current].classList.add('text-text', 'font-medium');
  }

  document.getElementById('slide-prev')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('slide-next')?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((dot) => {
    dot.addEventListener('click', () => goTo(Number(dot.getAttribute('data-goto'))));
  });

  // Auto-advance every 5 seconds
  setInterval(() => goTo(current + 1), 5000);
</script>
