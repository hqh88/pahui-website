---
import Layout from '../layouts/Layout.astro';
import productsData from '../data/products.json';

const collections = productsData.collections;
---

<Layout title="PA HUI Furniture - Premium Furniture Collection">
  <!-- Hero Section -->
  <section class="relative h-[70vh] min-h-[500px] overflow-hidden">
    <img
      src="/images/hero/hero-1.jpeg"
      alt="PA HUI Furniture"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/30"></div>
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="text-center bg-white/90 px-12 py-10 rounded-lg max-w-lg">
        <h1 class="font-heading text-3xl md:text-4xl font-bold text-text mb-3">PA HUI Furniture</h1>
        <p class="text-text-light mb-6">Premium Quality Furniture for Your Home</p>
        <a
          href="/collections"
          class="inline-block px-8 py-3 border-2 border-primary text-primary hover:bg-primary hover:text-white transition-colors text-sm font-medium tracking-wide"
        >
          Shop Now
        </a>
      </div>
    </div>
  </section>

  <!-- Shop by Collection -->
  <section class="max-w-7xl mx-auto px-4 py-16">
    <h2 class="font-heading text-2xl md:text-3xl font-semibold text-center mb-12">Shop by Collection</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {collections.map((col) => (
        <a href={`/collections/${col.slug}`} class="group text-center">
          <div class="aspect-square bg-bg-alt rounded-lg overflow-hidden mb-3">
            <img
              src={col.image}
              alt={col.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <h3 class="text-sm font-medium group-hover:text-primary transition-colors">{col.name}</h3>
        </a>
      ))}
    </div>
  </section>

  <!-- Feature Images Section -->
  <section class="max-w-7xl mx-auto px-4 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="relative aspect-[4/3] rounded-lg overflow-hidden group">
        <img src="/images/hero/hero-6.jpg" alt="Living Room" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition-colors"></div>
        <div class="absolute bottom-6 left-6">
          <h3 class="font-heading text-xl text-white font-semibold">Living Room</h3>
          <a href="/collections/sofas" class="text-white/80 text-sm hover:text-white transition-colors">Explore &rarr;</a>
        </div>
      </div>
      <div class="relative aspect-[4/3] rounded-lg overflow-hidden group">
        <img src="/images/hero/hero-7.jpg" alt="Bedroom" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition-colors"></div>
        <div class="absolute bottom-6 left-6">
          <h3 class="font-heading text-xl text-white font-semibold">Bedroom</h3>
          <a href="/collections/beds" class="text-white/80 text-sm hover:text-white transition-colors">Explore &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Middle Feature Images -->
  <section class="max-w-7xl mx-auto px-4 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="relative aspect-square rounded-lg overflow-hidden group">
        <img src="/images/hero/hero-4.jpg" alt="Dining" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition-colors"></div>
        <div class="absolute bottom-6 left-6">
          <h3 class="font-heading text-lg text-white font-semibold">Dining</h3>
        </div>
      </div>
      <div class="relative aspect-square rounded-lg overflow-hidden group">
        <img src="/images/hero/hero-5.jpg" alt="Accent Chairs" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition-colors"></div>
        <div class="absolute bottom-6 left-6">
          <h3 class="font-heading text-lg text-white font-semibold">Accent</h3>
        </div>
      </div>
      <div class="relative aspect-square rounded-lg overflow-hidden group">
        <img src="/images/hero/hero-2.jpg" alt="Tables" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition-colors"></div>
        <div class="absolute bottom-6 left-6">
          <h3 class="font-heading text-lg text-white font-semibold">Tables</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- Info Banner -->
  <section class="bg-primary-light py-16">
    <div class="max-w-3xl mx-auto text-center px-4">
      <h2 class="font-heading text-2xl md:text-3xl font-semibold mb-4">Quality Craftsmanship</h2>
      <p class="text-text-light mb-6 leading-relaxed">
        Every piece in our collection is carefully selected for its quality, design, and durability.
        We believe your home deserves furniture that combines beauty with lasting comfort.
      </p>
      <a
        href="/about"
        class="inline-block px-8 py-3 bg-primary text-white hover:bg-primary-dark transition-colors text-sm font-medium tracking-wide"
      >
        Learn More
      </a>
    </div>
  </section>
</Layout>
