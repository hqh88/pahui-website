---
import Layout from '../layouts/Layout.astro';
import productsData from '../data/products.json';

const collections = productsData.collections;
---

<Layout title="PA HUI Furniture - Premium Furniture Collection">
  <!-- Hero Section -->
  <section class="relative h-[70vh] min-h-[500px] overflow-hidden">
    <img
      src="/images/hero/hero-1.jpeg"
      alt="PA HUI Furniture"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/30"></div>
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="text-center bg-white/90 px-12 py-10 rounded-lg max-w-lg">
        <h1 class="font-heading text-3xl md:text-4xl font-bold text-text mb-3">PA HUI Furniture</h1>
        <p class="text-text-light mb-6">Premium Quality Furniture for Your Home</p>
        <a
          href="/collections"
          class="inline-block px-8 py-3 border-2 border-primary text-primary hover:bg-primary hover:text-white transition-colors text-sm font-medium tracking-wide"
        >
          Shop Now
        </a>
      </div>
    </div>
  </section>

  <!-- Shop by Collection -->
  <section class="max-w-7xl mx-auto px-4 py-16">
    <h2 class="font-heading text-2xl md:text-3xl font-semibold text-center mb-12">Shop by Collection</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {[
        { name: "Sofas", slug: "sofas", image: "/images/hero/hero-4.jpg" },
        { name: "Tables", slug: "dining-tables", image: "/images/hero/hero-5.jpg" },
        { name: "Arm Chairs", slug: "arm-chairs", image: "/images/hero/hero-6.jpg" },
        { name: "Beds", slug: "beds", image: "/images/hero/hero-7.jpg" },
      ].map((item) => (
        <a href={`/collections/${item.slug}`} class="group text-center">
          <div class="aspect-square bg-bg-alt rounded-lg overflow-hidden mb-3">
            <img
              src={item.image}
              alt={item.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <h3 class="text-sm font-medium group-hover:text-primary transition-colors">{item.name}</h3>
        </a>
      ))}
    </div>
  </section>

  <!-- Feature Images Section -->
  <section class="max-w-7xl mx-auto px-4 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="relative aspect-[4/3] rounded-lg overflow-hidden group">
        <img src="/images/hero/hero-6.jpg" alt="Living Room" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition-colors"></div>
        <div class="absolute bottom-6 left-6">
          <h3 class="font-heading text-xl text-white font-semibold">Living Room</h3>
          <a href="/collections/sofas" class="text-white/80 text-sm hover:text-white transition-colors">Explore &rarr;</a>
        </div>
      </div>
      <div class="relative aspect-[4/3] rounded-lg overflow-hidden group">
        <img src="/images/hero/hero-7.jpg" alt="Bedroom" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition-colors"></div>
        <div class="absolute bottom-6 left-6">
          <h3 class="font-heading text-xl text-white font-semibold">Bedroom</h3>
          <a href="/collections/beds" class="text-white/80 text-sm hover:text-white transition-colors">Explore &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Middle Feature Images -->
  <section class="max-w-7xl mx-auto px-4 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="relative aspect-square rounded-lg overflow-hidden group">
        <img src="/images/hero/hero-4.jpg" alt="Dining" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition-colors"></div>
        <div class="absolute bottom-6 left-6">
          <h3 class="font-heading text-lg text-white font-semibold">Dining</h3>
        </div>
      </div>
      <div class="relative aspect-square rounded-lg overflow-hidden group">
        <img src="/images/hero/hero-5.jpg" alt="Accent Chairs" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition-colors"></div>
        <div class="absolute bottom-6 left-6">
          <h3 class="font-heading text-lg text-white font-semibold">Accent</h3>
        </div>
      </div>
      <div class="relative aspect-square rounded-lg overflow-hidden group">
        <img src="/images/hero/hero-2.jpg" alt="Tables" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition-colors"></div>
        <div class="absolute bottom-6 left-6">
          <h3 class="font-heading text-lg text-white font-semibold">Tables</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- Slideshow -->
  <section class="relative overflow-hidden" id="slideshow">
    <div class="relative h-[50vh] min-h-[400px]">
      <!-- Slides -->
      <div class="slide absolute inset-0 transition-opacity duration-700 opacity-100" data-slide="0">
        <img src="/images/hero/slide-1.jpg" alt="Custom Design" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0 bg-black/30"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="bg-white/90 px-10 py-8 max-w-xl text-center rounded">
            <h2 class="font-heading text-2xl md:text-3xl font-semibold mb-3">Custom Design Services</h2>
            <p class="text-text-light leading-relaxed">
              We offer personalized design consultations to help you find the perfect pieces for your space.
            </p>
          </div>
        </div>
      </div>
      <div class="slide absolute inset-0 transition-opacity duration-700 opacity-0" data-slide="1">
        <img src="/images/hero/slide-2.jpg" alt="Quality Craftsmanship" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0 bg-black/30"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="bg-white/90 px-10 py-8 max-w-xl text-center rounded">
            <h2 class="font-heading text-2xl md:text-3xl font-semibold mb-3">Quality Craftsmanship</h2>
            <p class="text-text-light leading-relaxed">
              Every piece is carefully selected for quality, design, and durability to ensure lasting comfort.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Controls -->
    <div class="flex items-center justify-center gap-4 py-4 bg-white">
      <button id="slide-prev" class="text-text-light hover:text-text text-xl" aria-label="Previous slide">&lsaquo;</button>
      <button class="slide-dot text-sm font-medium text-text" data-goto="0">1</button>
      <button class="slide-dot text-sm text-text-light" data-goto="1">2</button>
      <button id="slide-next" class="text-text-light hover:text-text text-xl" aria-label="Next slide">&rsaquo;</button>
    </div>
  </section>
</Layout>

<script>
  let current = 0;
  const slides = document.querySelectorAll('.slide');
  const dots = document.querySelectorAll('.slide-dot');
  const total = slides.length;

  function goTo(index: number) {
    slides[current].classList.remove('opacity-100');
    slides[current].classList.add('opacity-0');
    dots[current].classList.remove('text-text', 'font-medium');
    dots[current].classList.add('text-text-light');

    current = (index + total) % total;

    slides[current].classList.remove('opacity-0');
    slides[current].classList.add('opacity-100');
    dots[current].classList.remove('text-text-light');
    dots[current].classList.add('text-text', 'font-medium');
  }

  document.getElementById('slide-prev')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('slide-next')?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((dot) => {
    dot.addEventListener('click', () => goTo(Number(dot.getAttribute('data-goto'))));
  });

  // Auto-advance every 5 seconds
  setInterval(() => goTo(current + 1), 5000);
</script>
