---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import productsData from '../../data/products.json';

export function getStaticPaths() {
  const paths: any[] = [];
  productsData.collections.forEach((col) => {
    col.products.forEach((product) => {
      paths.push({
        params: { id: product.id },
        props: { product, collection: col },
      });
    });
  });
  return paths;
}

const { product, collection } = Astro.props;

// Get related products (same collection, excluding current)
const related = collection.products
  .filter((p: any) => p.id !== product.id)
  .slice(0, 4);
---

<Layout title={`${product.name} - PA HUI Furniture`}>
  <section class="max-w-7xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-text-light mb-8">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href={`/collections/${collection.slug}`} class="hover:text-primary transition-colors">{collection.name}</a>
      <span class="mx-2">/</span>
      <span class="text-text">{product.name}</span>
    </nav>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Product Image -->
      <div class="bg-bg-alt rounded-lg overflow-hidden">
        <img
          src={product.image}
          alt={product.name}
          class="w-full h-auto object-contain p-8"
        />
      </div>

      <!-- Product Info -->
      <div class="flex flex-col justify-center">
        <h1 class="font-heading text-2xl md:text-3xl font-semibold mb-4">{product.name}</h1>
        <p class="text-text-light mb-2 capitalize">Category: {product.category.replace(/-/g, ' ')}</p>
        <p class="text-text-light mb-2">SKU: {product.id}</p>

        <div class="border-t border-border my-6 pt-6">
          <p class="text-text-light leading-relaxed mb-6">
            This premium furniture piece is crafted with attention to detail and quality materials.
            Contact us for pricing, availability, and customization options.
          </p>
          <a
            href="/contact"
            class="inline-block px-8 py-3 bg-primary text-white hover:bg-primary-dark transition-colors text-sm font-medium tracking-wide"
          >
            Inquire Now
          </a>
        </div>
      </div>
    </div>

    <!-- Related Products -->
    {related.length > 0 && (
      <div class="mt-16">
        <h2 class="font-heading text-xl font-semibold mb-8">You May Also Like</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {related.map((p: any) => (
            <ProductCard
              id={p.id}
              name={p.name}
              image={p.image}
              category={p.category}
            />
          ))}
        </div>
      </div>
    )}
  </section>
</Layout>
