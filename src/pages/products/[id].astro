---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getCollectionsWithProducts } from '../../data/reader';

export const prerender = true;

export async function getStaticPaths() {
  const collections = await getCollectionsWithProducts();
  const paths: any[] = [];
  collections.forEach((col) => {
    col.products.forEach((product) => {
      paths.push({
        params: { id: product.id },
        props: { product, collection: col },
      });
    });
  });
  return paths;
}

const { product, collection } = Astro.props;

// Get related products (same collection, excluding current)
const related = collection.products
  .filter((p: any) => p.id !== product.id)
  .slice(0, 4);
---

<Layout
  title={`${product.name} - PA HUI Furniture`}
  description={`${product.name} - ${product.category.replace(/-/g, ' ')}${product.size ? `, ${product.size}` : ''}. Premium furniture from PA HUI.`}
  ogImage={product.image}
>
  <section class="max-w-7xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-text-light mb-8">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href={`/collections/${collection.slug}`} class="hover:text-primary transition-colors">{collection.name}</a>
      <span class="mx-2">/</span>
      <span class="text-text">{product.name}</span>
    </nav>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Product Image -->
      <div class="bg-bg-alt rounded-lg overflow-hidden">
        <img
          src={product.image}
          alt={product.name}
          class="w-full h-auto object-contain p-8"
        />
      </div>

      <!-- Product Info -->
      <div class="flex flex-col justify-center">
        <h1 class="font-heading text-2xl md:text-3xl font-semibold mb-4">{product.name}</h1>
        <p class="text-text-light mb-2 capitalize">Category: {product.category.replace(/-/g, ' ')}</p>
        <p class="text-text-light mb-2">SKU: {product.id}</p>

        <!-- Size Info -->
        {product.size && (
          <div class="mt-4 p-4 bg-bg-alt rounded-lg">
            <h3 class="text-sm font-semibold mb-2">Dimensions</h3>
            <p class="text-text-light text-sm">
              {product.size.includes('/') ? (
                <span>
                  {product.size.split(' / ').map((s: string, i: number) => (
                    <span class="block">{s.replace(/\*/g, ' × ')}</span>
                  ))}
                </span>
              ) : (
                <span>{product.size.replace(/\*/g, ' × ')}</span>
              )}
            </p>
            {product.customizable && (
              <p class="text-primary text-xs mt-2 font-medium">Size can be customized</p>
            )}
          </div>
        )}
        {!product.size && product.customizable && (
          <div class="mt-4 p-4 bg-bg-alt rounded-lg">
            <p class="text-primary text-sm font-medium">Size can be customized</p>
          </div>
        )}

        <!-- Request a Price (collapsible) -->
        <div class="border-t border-border my-6">
          <button
            id="price-toggle"
            class="w-full flex items-center justify-between py-4 text-left"
          >
            <span class="flex items-center gap-2 font-heading text-lg font-semibold">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5a1.99 1.99 0 011.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.99 1.99 0 013 12V7a4 4 0 014-4z" />
              </svg>
              Request a Price
            </span>
            <svg id="price-chevron" class="w-5 h-5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <div id="price-panel" class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out">
           <div class="overflow-hidden">
            <div class="pb-6">
            <p class="text-text-light text-center mb-2">
              Most of our furniture pieces offer multiple size, fabric, and configuration options, which can affect pricing.
            </p>
            <p class="text-text-light text-center mb-6">
              We provide personalized quotes to make sure you receive the most accurate price and available promotions.
            </p>

            <form id="price-form" class="space-y-4 max-w-md mx-auto">
              <div>
                <label for="req-name" class="block text-sm text-text-light mb-1">Name <span class="text-red-500">*</span></label>
                <input type="text" id="req-name" name="name" required
                  class="w-full px-3 py-2 border-b border-border bg-transparent focus:outline-none focus:border-primary transition-colors" />
              </div>
              <div>
                <label for="req-email" class="block text-sm text-text-light mb-1">Email Address <span class="text-red-500">*</span></label>
                <input type="email" id="req-email" name="email" required
                  class="w-full px-3 py-2 border-b border-border bg-transparent focus:outline-none focus:border-primary transition-colors" />
              </div>
              <div>
                <label for="req-phone" class="block text-sm text-text-light mb-1">Phone</label>
                <input type="tel" id="req-phone" name="phone"
                  class="w-full px-3 py-2 border-b border-border bg-transparent focus:outline-none focus:border-primary transition-colors" />
              </div>
              <div>
                <label for="req-message" class="block text-sm text-text-light mb-1">Message</label>
                <textarea id="req-message" name="message" rows="3"
                  class="w-full px-3 py-2 border-b border-border bg-transparent focus:outline-none focus:border-primary transition-colors resize-y"
                ></textarea>
              </div>
              <input type="hidden" name="product" value={`${product.name} (${product.id})`} />
              <div class="text-center pt-2">
                <button type="submit"
                  class="px-10 py-3 bg-primary text-white hover:bg-primary-dark transition-colors text-sm font-medium tracking-wide">
                  Submit
                </button>
              </div>
            </form>
            </div>
           </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Related Products -->
    {related.length > 0 && (
      <div class="mt-16">
        <h2 class="font-heading text-xl font-semibold mb-8">You May Also Like</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {related.map((p: any) => (
            <ProductCard
              id={p.id}
              name={p.name}
              image={p.image}
              category={p.category}
              size={p.size}
              customizable={p.customizable}
            />
          ))}
        </div>
      </div>
    )}
  </section>
</Layout>

<script>
  const toggle = document.getElementById('price-toggle');
  const panel = document.getElementById('price-panel');
  const chevron = document.getElementById('price-chevron');

  toggle?.addEventListener('click', () => {
    const isOpen = panel?.classList.contains('grid-rows-[1fr]');
    if (isOpen) {
      panel?.classList.remove('grid-rows-[1fr]');
      panel?.classList.add('grid-rows-[0fr]');
      chevron?.classList.remove('rotate-180');
    } else {
      panel?.classList.remove('grid-rows-[0fr]');
      panel?.classList.add('grid-rows-[1fr]');
      chevron?.classList.add('rotate-180');
    }
  });

  // Umami: track product view
  const productMeta = document.querySelector('input[name="product"]') as HTMLInputElement;
  if (productMeta) {
    (window as any).umami?.track('product-view', { product: productMeta.value });
  }

  document.getElementById('price-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    // Umami: track price request
    (window as any).umami?.track('price-request', { product: productMeta?.value });
    alert('Thank you! We will get back to you with a personalized quote soon.');
    (e.target as HTMLFormElement).reset();
    panel?.classList.remove('grid-rows-[1fr]');
    panel?.classList.add('grid-rows-[0fr]');
    chevron?.classList.remove('rotate-180');
  });
</script>
